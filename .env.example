# ─────────────────────────────────────────────────────────────
#  AI News Dashboard — environment configuration
#  Copy to `.env` and fill in values.  `.env` is git-ignored.
# ─────────────────────────────────────────────────────────────

# Postgres connection string.
#  • Supabase: Project → Settings → Database → Connection string (URI).
#    Use the "Transaction" pooler (port 6543) for serverless/Next.js.
#    Example: postgresql://postgres.xxxx:[PASSWORD]@aws-0-region.pooler.supabase.com:6543/postgres
#  • Local docker-compose: postgresql://postgres:postgres@localhost:5432/ainews
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ainews"

# OpenAI — powers summaries, LinkedIn captions, and semantic-dedup embeddings.
# Leave blank to run in MOCK mode (deterministic summaries, no embeddings, no cost).
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
OPENAI_EMBED_MODEL="text-embedding-3-small"

# Ingestion tuning
INGEST_ITEMS_PER_SOURCE="15"   # max items pulled per feed per run
ENRICH_LIMIT="40"              # max NEW items sent to OpenAI per run (cost guard)
DEDUP_TITLE_THRESHOLD="0.82"   # fuzzy title Jaccard similarity → duplicate
DEDUP_COSINE_THRESHOLD="0.88"  # embedding cosine similarity → duplicate

# Scheduled worker: minutes between ingestion passes (npm run worker).
INGEST_INTERVAL_MINUTES="15"

# Secret required to trigger POST /api/ingest from the worker / cron.
INGEST_SECRET="change-me-in-production"

# Public base URL (used by the cron worker to call the app). Optional locally.
APP_URL="http://localhost:3000"
